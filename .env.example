# Required: OpenAI (engineering_lead and code_reviewer use gpt-4o by default)
OPENAI_API_KEY=your_openai_key_here

# Required: Anthropic (backend/frontend/test engineers use claude-3-7-sonnet by default)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: override default LLMs per agent role
# LEAD_LLM=gpt-4o
# ENGINEER_LLM=anthropic/claude-3-7-sonnet-latest
# REVIEWER_LLM=gpt-4o

# Optional: code execution sandbox mode for backend_engineer and test_engineer
# "unsafe" = local execution (default, no Docker required)
# "safe"   = Docker sandbox (requires Docker to be running)
# CODE_EXECUTION_MODE=unsafe
